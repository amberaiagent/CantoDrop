# ── trench bot config ── copy to .env and fill in. NEVER commit .env. ──

# Solana RPC. Helius is strongly recommended — enumerating holders (#1–#1000)
# needs an indexed endpoint. Free key at helius.dev.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Private key of the DEPOSIT/POOL wallet (the one that holds the locked supply
# and sends the drops). base58 string OR a JSON array like [12,34,...].
# This is a SECRET. It lives only here, never in git.
DEPOSIT_WALLET_SECRET=

# The trench site API + the SAME ADMIN_TOKEN that's in the site's .env.
# The bot reads orders and writes status through this.
API_BASE=https://trenchdrop.xyz
ADMIN_TOKEN=

# SAFETY SWITCH. true = simulate only (logs intended drops, sends nothing).
# Keep true until you've tested on devnet. Flip to false to go live.
DRY_RUN=true

# Poll interval in seconds.
POLL_INTERVAL=30

# Extra addresses to always exclude from snapshots (comma-separated): team,
# CEX, market makers, etc. The on-chain liquidity pool is auto-detected and
# excluded too, but list anything else you don't want to reward.
EXCLUDE_ADDRESSES=
