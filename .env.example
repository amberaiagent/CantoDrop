# Copy to .env and fill in.

# Port the app listens on INSIDE the container. Keep 3000.
# The PUBLIC port is set in docker-compose.yml (HOST_PORT, default 80).
PORT=3000

# Public port mapped to the app. Defaults to 80 in docker-compose.yml.
# HOST_PORT=80

# PostgreSQL connection string
# e.g. postgres://user:password@localhost:5432/canto_drop
DATABASE_URL=postgres://postgres:postgres@localhost:5432/canto_drop

# The single public deposit wallet all devs send supply to.
# The bot watches this wallet and matches incoming transfers by memo (reference) + token mint.
DEPOSIT_WALLET=H34PbZN5gxckdVs9wSEvtF4oVcXrzwXQtgMiwtYCJBAH

# Password for the /admin panel and PATCH /api/orders. Leave blank to keep them open
# (local dev). Set to a long random string in production.
ADMIN_TOKEN=
